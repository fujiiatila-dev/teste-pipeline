# ============================================================================
# teste-pipeline — Variáveis de Ambiente
# ============================================================================
# Copie este arquivo para .env e preencha os valores necessários:
#   cp .env.example .env
#
# NOTA: As credenciais de cada conector são opcionais. Preencha apenas
# as plataformas que você utiliza. Credenciais também podem ser configuradas
# via Google Sheets (GSheetsManager) ou Prefect Variables (UI).
# ============================================================================

# ── Infraestrutura (OBRIGATÓRIO) ─────────────────────────────────────────────

# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=nalk_worker
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=marketing

# MinIO / Data Lake (S3-compatible)
MINIO_ENDPOINT=http://localhost:9000
MINIO_EXTERNAL_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=

# Prefect (definido automaticamente pelo docker-compose)
# PREFECT_API_URL=http://prefect-server:4200/api

# Alertas por Email (health check, falhas de flow)
ALERT_EMAIL_TO=suporte@nalk.com.br
ALERT_EMAIL_FROM=pipeline@nalk.com.br
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Backoffice Webhook (notificações de status)
# BACKOFFICE_ENDPOINT=https://ai.nalk.com.br
# BACKOFFICE_AUTH_TOKEN=

# ── Ads & Marketing ──────────────────────────────────────────────────────────

# Meta Ads (Facebook/Instagram)
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=              # System User Token (longa duração)
# META_AD_ACCOUNT_IDS=act_123,act_456

# Google Ads
# GOOGLE_ADS_DEVELOPER_TOKEN=
# GOOGLE_ADS_CLIENT_ID=
# GOOGLE_ADS_CLIENT_SECRET=
# GOOGLE_ADS_REFRESH_TOKEN=
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=
# GOOGLE_ADS_CUSTOMER_ID=

# RD Marketing (RD Station) — credenciais via Google Sheets

# Brevo (ex-Sendinblue)
# BREVO_API_KEY=

# Mautic
# MAUTIC_BASE_URL=https://mautic.exemplo.com.br
# MAUTIC_CLIENT_ID=
# MAUTIC_CLIENT_SECRET=

# Active Campaign — credenciais via Google Sheets

